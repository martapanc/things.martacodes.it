---
interface Props {
    href?: string;
    class?: string;
    padded?: boolean;
    /** Set false when the tile brings its own colours — two competing `bg-*`
     *  (or `border-*`) utilities resolve by stylesheet order, not class
     *  order, so the default surface has to be left off entirely. */
    surface?: boolean;
}

const {
    href,
    class: className = '',
    padded = true,
    surface = true,
} = Astro.props;

// Renders as a link when it leads somewhere, otherwise a plain surface
const Tag = href ? 'a' : 'div';
const attrs = href
    ? { href, ...(href.startsWith('http') ? { rel: 'noopener' } : {}) }
    : {};

const base =
    'group relative flex flex-col overflow-hidden rounded-[1.75rem] border transition duration-300 ease-out';
// Warm off-white rather than pure white — it reads softer against the page
const surfaceClasses = surface
    ? 'border-stone-200/70 bg-[#fffcf8] shadow-sm shadow-stone-900/3 dark:border-slate-700/60 dark:bg-slate-900/60 dark:shadow-none'
    : '';
const interactive = href
    ? 'hover:-translate-y-1 hover:shadow-xl hover:shadow-stone-900/8 dark:hover:shadow-none'
    : '';
---

<Tag
    {...attrs}
    class={`${base} ${surfaceClasses} ${interactive} ${padded ? 'p-5 md:p-6' : ''} ${className}`}
>
    <slot />
</Tag>
