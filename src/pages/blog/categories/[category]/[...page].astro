---
import BlogLayout from '@/layouts/BlogLayout.astro';
import PostPreviewDisplay from '@/components/PostPreviewDisplay.astro';
import Pagination from '@/components/molecules/Pagination.astro';
import {
    getAllPostPreviews,
    listCategoriesWithCounts,
    POSTS_PER_PAGE,
} from '@/lib/posts';
import { allCategories } from '@/types/Post';
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
    const allPosts = await getAllPostPreviews();
    const categories = listCategoriesWithCounts(allPosts);

    return Object.keys(categories).flatMap((category) =>
        paginate(
            allPosts.filter((p) => p.data.category === category),
            { params: { category }, pageSize: POSTS_PER_PAGE }
        )
    );
};

interface Props {
    page: Page<CollectionEntry<'posts'>>;
}

const { category } = Astro.params;
const { page } = Astro.props;

const breadcrumbs = {
    past: [
        { path: '/blog', label: 'Blog' },
        { path: '/blog/categories', label: 'Categories' },
    ],
    current: allCategories[category!],
};
---

<BlogLayout
    title={`${allCategories[category!]} | Marta Makes Things`}
    breadcrumbs={breadcrumbs}
>
    <h1>Category: {allCategories[category!]}</h1>

    <section>
        <div class='flex flex-col gap-6 py-6'>
            {page.data.map((post) => <PostPreviewDisplay post={post} />)}
        </div>
    </section>

    <Pagination page={page} />
</BlogLayout>
