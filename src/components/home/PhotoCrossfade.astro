---
interface Props {
    images: (string | undefined)[];
    /** Seconds for one full loop through every image */
    duration?: number;
    class?: string;
}

const { images, duration = 20, class: className = '' } = Astro.props;

// Up to four layers: one keyframe set per count, so each image gets an equal slot
const layers = images.filter((src): src is string => !!src).slice(0, 4);
const count = layers.length;

/**
 * Negative delays start every layer part-way through the loop. The extra half
 * slot means the first image sits mid-hold on load, so nothing is caught
 * mid-fade before the visitor has even looked at it.
 */
const delayFor = (index: number) => -((index + 0.5) * duration) / count;
---

{
    count === 0 && (
        <div
            class={`absolute inset-0 bg-gradient-to-br from-sky-200 to-blue-300 dark:from-sky-900 dark:to-blue-950 ${className}`}
        />
    )
}

{
    layers.map((src, index) => (
        <img
            src={src}
            alt=''
            loading='lazy'
            class={`cross-fade absolute inset-0 h-full w-full object-cover ${className}`}
            style={
                count > 1
                    ? `animation-name: cross-fade-${count};` +
                      `animation-duration: ${duration}s;` +
                      'animation-timing-function: linear;' +
                      'animation-iteration-count: infinite;' +
                      `animation-delay: ${delayFor(index).toFixed(2)}s;`
                    : 'opacity: 1;'
            }
        />
    ))
}
