CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SITE_URL=https://things.martacodes.it

# Used by the /upload page, which runs in the browser — must be PUBLIC_ to be
# exposed client-side. Same value as CLOUDINARY_CLOUD_NAME above (not a
# secret; it's already visible in every image URL on the site).
PUBLIC_CLOUDINARY_CLOUD_NAME=

# SHA-256 hex digest of the PIN that unlocks /upload, e.g.:
#   printf '1234' | shasum -a 256
# Never put the plaintext PIN here — only the hash.
PUBLIC_UPLOAD_PIN_HASH=
